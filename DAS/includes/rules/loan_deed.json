{
    "document_type": "loan_deed",
    "description": "Loan Deed (Tamasuk) - Loan agreement document",
    "data_sources": {
        "borrowers": {
            "table": "borrowers",
            "prefix": "BR",
            "max_count": 5,
            "fields_mapping": "person_fields",
            "description": "Primary borrowers who are taking the loan"
        },
        "guarantors": {
            "table": "guarantors",
            "prefix": "GR",
            "max_count": 5,
            "fields_mapping": "person_fields",
            "description": "Guarantors who guarantee the loan repayment"
        },
        "collateral_owners": {
            "source": "collateral.owner_id",
            "prefix": "CO",
            "fields_mapping": "person_fields",
            "description": "Owners of the collateral property"
        },
        "collateral": {
            "table": "collateral",
            "prefix": "COL",
            "fields_mapping": "collateral_fields",
            "description": "Collateral/property details"
        },
        "loan": {
            "table": "loan_details",
            "prefix": "LN",
            "fields_mapping": "loan_fields",
            "description": "Loan details"
        },
        "bank": {
            "source": "system_settings",
            "prefix": "BNK",
            "fields_mapping": "bank_fields",
            "description": "Bank/branch information"
        },
        "witnesses": {
            "manual": true,
            "prefix": "WIT",
            "fields_mapping": "witness_fields",
            "description": "Witnesses"
        }
    },
    "validation_rules": {
        "required_borrowers": 1,
        "required_collateral": 0,
        "required_collateral_owners": 0
    },
    "processing_order": [
        "bank",
        "loan",
        "borrowers",
        "guarantors",
        "collateral",
        "collateral_owners",
        "witnesses"
    ]
}